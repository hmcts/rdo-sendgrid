{
    "$schema": "http://schema.management.azure.com/schemas/2015-01-01-preview/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "name": {
            "type": "String"
        },
        "planId": {
            "type": "String"
        },
        "termId": {
            "type": "String"
        },
        "azureSubscriptionId": {
            "type": "String"
        },
        "autoRenew": {
            "type": "Bool"
        },
        "storeFront": {
            "type": "String"
        },
        "tags": {
            "type": "Object"
        }
    },
    "resources": [
        {
            "type": "Microsoft.SaaS/resources",
            "apiVersion": "2018-03-01-beta",
            "name": "[parameters('name')]",
            "location": "global",
            "tags": "[parameters('tags')]",
            "properties": {
                "purchaserEmail": "DTSPlatformOps@HMCTS.NET",
                "beneficiaryEmail": "DTSPlatformOps@HMCTS.NET",
                "autoRenew": "[parameters('autoRenew')]",
                "market": "GB",
                "offerName": "Twilio SendGrid",
                "saasResourceName": "[parameters('name')]",
                "publisherId": "sendgrid",
                "publisherName": "SendGrid",
                "SKUId": "[parameters('planId')]",
                "offerId": "tsg-saas-offer",
                "termId": "[parameters('termId')]",
                "paymentChannelType": "SubscriptionDelegated",
                "paymentChannelMetadata": {
                    "AzureSubscriptionId": "[parameters('azureSubscriptionId')]"
                },
                "storeFront": "[parameters('storeFront')]"
            }
        }
    ]
}